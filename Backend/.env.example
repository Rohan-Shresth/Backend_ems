NODE_ENV=development
PORT=0
# Atlas SRV format (default): mongodb+srv://<username>:<url_encoded_password>@<cluster-url>/<db-name>?retryWrites=true&w=majority&appName=<app-name>
# Atlas direct format (useful when SRV DNS is blocked): mongodb://<username>:<url_encoded_password>@<host1>:27017,<host2>:27017,<host3>:27017/<db-name>?ssl=true&authSource=admin&replicaSet=<replica-set>&retryWrites=true&w=majority&appName=<app-name>
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/event_management?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI_DIRECT=
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=1d
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_EXPOSE_IN_RESPONSE=false

# SMTP settings for OTP email delivery
# Example host/port:
# - Gmail: smtp.gmail.com / 587 (secure=false)
# - Brevo: smtp-relay.brevo.com / 587 (secure=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password_or_app_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Event Management System
